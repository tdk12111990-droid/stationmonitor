# ── Large Binaries (Blockers for GitHub) ──
*.rar
*.zip
*.7z
*.tar.gz
*.exe
*.dll
*.so
*.dylib
*.bin

# ── .NET / C# ──
bin/
obj/
[Ee]xpress/
*.user
*.userosscache
*.sln.docuser
.vs/
.vscode/
*.suo
*.user
*.userosscache
*.sln.docuser
*.swp
*.bak
*.log

# ── Node.js / Frontend ──
node_modules/
dist/
build/
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.parcel-cache
.cache
.next
out/

# ── Tauri ──
src-tauri/target/
src-tauri/binaries/
src-tauri/gen/

# ── Python / AI ──
__pycache__/
*.py[cod]
*$py.class
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
enhanced_relay.log
ffmpeg_relay.log
ai_diagnostics.log

# ── Databases ──
data/pgdata/
data/mosquitto/data/
data/mosquitto/log/
*.db
*.sqlite

# ── Media ──
wwwroot/detections/
wwwroot/videos/
wwwroot/data/media/

# ── System / OS ──
.DS_Store
Thumbs.db
Desktop.ini
