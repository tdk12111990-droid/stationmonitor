# ============================================================
# .gitignore — StationMonitor Project
# ============================================================

# ── Large Binaries (Blockers for GitHub) ──
*.rar
*.zip
*.7z
*.tar.gz
*.exe
*.dll
*.so
*.dylib
*.bin

# ── .NET / C# ──
bin/
obj/
[Ee]xpress/
*.user
*.userosscache
*.sln.docuser
.vs/
.vscode/
*.suo
*.user
*.userosscache
*.sln.docuser
*.swp
*.bak
*.log

# ── Node.js / Frontend ──
node_modules/
dist/
build/
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.parcel-cache
.cache
.next
out/

# ── Tauri ──
src-tauri/target/
src-tauri/binaries/
src-tauri/gen/

# ── Python / AI ──
__pycache__/
*.py[cod]
*$py.class
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
enhanced_relay.log
ffmpeg_relay.log
ai_diagnostics.log

# ── Databases ──
data/pgdata/
data/mosquitto/data/
data/mosquitto/log/
*.db
*.sqlite

# ── Media (generated at runtime) ──
wwwroot/detections/
wwwroot/videos/
wwwroot/media/
wwwroot/data/media/
wwwroot/reports/
alerts/
*.jpg
*.jpeg
*.png
!frontend/public/*.png
*.mp4
*.avi

# ── SDK binaries (download separately - too large for git) ──
sdk-relay/test_sdk/lib/windows/*.dll
sdk-relay/test_sdk/lib/windows/*.exe
sdk-relay/test_sdk/lib/windows/*.lib
sdk-relay/test_sdk/lib/windows/ClientDemoDll/
sdk-relay/test_sdk/lib/linux/*.so
sdk-relay/test_sdk/lib/linux/*.so.*
sdk-relay/test_sdk/lib/linux/HCNetSDKCom/
sdk-relay/test_sdk/lib/*.exe
sdk-relay/test_sdk/lib/*.zip

# ── Claude memory (local only) ──
.claude/

# ── System / OS ──
.DS_Store
Thumbs.db
Desktop.ini
